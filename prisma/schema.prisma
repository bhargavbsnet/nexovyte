datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model ContactSubmission {
  id          String   @id @default(uuid())
  name        String
  email       String
  company     String?
  inquiryType String   // e.g. "Cloud Solutions", "SaaS Development", "Automation"
  message     String
  createdAt   DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  status    String   @default("active") // "active", "unsubscribed"
  createdAt DateTime @default(now())
}

model ConsultationBooking {
  id        String   @id @default(uuid())
  fullName  String
  email     String
  date      String
  timeSlot  String
  createdAt DateTime @default(now())
}

model ProductInquiry {
  id          String   @id @default(uuid())
  clientName  String
  email       String
  productType String   // e.g. "LexFlow Pro Team", "LexFlow Enterprise"
  message     String
  createdAt   DateTime @default(now())
}

model JobApplication {
  id           String   @id @default(uuid())
  fullName     String
  email        String
  position     String
  resumeUrl    String?
  coverLetter  String?
  createdAt    DateTime @default(now())
}
